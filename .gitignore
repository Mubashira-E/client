!.yarn/plugins
!.yarn/releases
!.yarn/versions

# next.js
/.next/
/out/
/build
.next
next-env.d.ts

# production
/build
/dist

# misc
.DS_Store
*.pem
Thumbs.db
desktop.ini

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
lerna-debug.log*

# local env files
.env*.local
.env
.env.development
.env.test
.env.production

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# IDE - VSCode
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace
.history/

# IDE - WebStorm/IntelliJ
.idea/
*.iml
*.iws
*.ipr
.idea_modules/

# Logs
logs
*.log

# Cache directories
.cache/
.temp/
.tmp/
.eslintcache
.stylelintcache

# Optional npm cache directory
.npm

# Optional eslint cache
.eslintcache

# Optional stylelint cache
.stylelintcache

# Optional REPL history
.node_repl_history

# Output of 'npm pack'
*.tgz

# Yarn Integrity file
.yarn-integrity

# parcel-bundler cache
.parcel-cache

# Storybook
storybook-static/

# Cypress
cypress/videos/
cypress/screenshots/

